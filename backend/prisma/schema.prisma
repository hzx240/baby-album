generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String             @map("password_hash")
  displayName    String?            @map("display_name")
  avatarUrl      String?            @map("avatar_url")
  familyId       String?            @map("family_id")
  status         String             @default("ACTIVE")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  auditLogs      AuditLog[]
  invitations    FamilyInvitation[] @relation("InviterInvitations")
  memberOf       FamilyMember[]     @relation("FamilyMember")
  uploadedPhotos Photo[]            @relation("PhotoUploader")
  refreshTokens  RefreshToken[]
  uploadTasks    UploadTask[]       @relation("UploadTasks")
  family         Family?            @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([status])
  @@map("users")
}

model Family {
  id             String             @id @default(uuid())
  name           String
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  albums         Album[]            @relation("FamilyAlbums")
  children       Child[]
  invitations    FamilyInvitation[]
  members        FamilyMember[]
  importantDates ImportantDate[]    @relation("ImportantDates")
  milestones     Milestone[]        @relation("FamilyMilestones")
  persons        Person[]           @relation("FamilyPersons")
  photos         Photo[]
  timelineStats  TimelineStats[]    @relation("TimelineStats")
  uploadTasks    UploadTask[]       @relation("UploadTasks")
  users          User[]
  shareLinks     ShareLink[]        @relation("FamilyShareLinks")

  @@index([createdAt(sort: Desc)])
  @@map("families")
}

model FamilyMember {
  id       String   @id @default(uuid())
  familyId String   @map("family_id")
  userId   String   @map("user_id")
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now()) @map("joined_at")
  user     User     @relation("FamilyMember", fields: [userId], references: [id], onDelete: Cascade)
  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
  @@map("family_members")
}

model FamilyInvitation {
  id        String    @id @default(uuid())
  familyId  String    @map("family_id")
  inviterId String    @map("inviter_id")
  token     String    @unique
  role      String    @default("MEMBER")
  email     String?
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  inviter   User      @relation("InviterInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  family    Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([familyId])
  @@index([expiresAt])
  @@map("family_invitations")
}

model Child {
  id                  String               @id @default(uuid())
  familyId            String               @map("family_id")
  name                String
  avatar              String?
  birthDate           DateTime?            @map("birth_date")
  gender              String?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  family              Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  importantDates      ImportantDate[]      @relation("ChildImportantDates")
  milestones          Milestone[]          @relation("ChildMilestones")
  photos              Photo[]
  timelineStats       TimelineStats[]      @relation("TimelineStats")
  uploadTasks         UploadTask[]         @relation("UploadTasks")
  growthRecords       GrowthRecord[]       @relation("ChildGrowthRecords")
  growthReports       GrowthReport[]       @relation("ChildGrowthReports")
  milestoneReminders  MilestoneReminder[]  @relation("ChildMilestoneReminders")

  @@index([familyId])
  @@index([familyId, createdAt(sort: Desc)])
  @@map("children")
}

model Photo {
  id              String           @id @default(uuid())
  familyId        String           @map("family_id")
  childId         String?          @map("child_id")
  uploaderId      String           @map("uploader_id")
  originalKey     String           @map("original_key")
  resizedKey      String?          @map("resized_key")
  thumbKey        String?          @map("thumb_key")
  takenAt         DateTime?        @map("taken_at")
  uploadedAt      DateTime         @default(now()) @map("uploaded_at")
  checksum        String?
  fileSize        Int?             @map("file_size")
  mimeType        String?          @map("mime_type")
  albumPhotos     AlbumPhoto[]     @relation("AlbumPhotos")
  photoMilestones Milestone[]      @relation("PhotoMilestones")
  faces           PhotoFace[]      @relation("PhotoFaces")
  tags            PhotoTag[]       @relation("PhotoTags")
  uploader        User             @relation("PhotoUploader", fields: [uploaderId], references: [id])
  child           Child?           @relation(fields: [childId], references: [id])
  family          Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  uploadTaskFiles UploadTaskFile[] @relation("UploadTaskFiles")

  @@index([familyId, uploadedAt(sort: Desc)])
  @@index([familyId, takenAt(sort: Desc)])
  @@index([childId, uploadedAt(sort: Desc)])
  @@index([childId, takenAt(sort: Desc)])
  @@index([familyId, checksum])
  @@map("photos")
}

model PhotoTag {
  photoId String @map("photo_id")
  tag     String
  photo   Photo  @relation("PhotoTags", fields: [photoId], references: [id], onDelete: Cascade)

  @@id([photoId, tag])
  @@map("photo_tags")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  targetId  String?  @map("target_id")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId(sort: Desc), createdAt(sort: Desc)])
  @@map("audit_logs")
}

model UploadTask {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  familyId      String           @map("family_id")
  childId       String?          @map("child_id")
  status        String           @default("PENDING")
  totalFiles    Int              @default(0) @map("total_files")
  uploadedFiles Int              @default(0) @map("uploaded_files")
  failedFiles   Int              @default(0) @map("failed_files")
  totalBytes    BigInt?          @map("total_bytes")
  uploadedBytes BigInt           @default(0) @map("uploaded_bytes")
  startedAt     DateTime?        @map("started_at")
  completedAt   DateTime?        @map("completed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  files         UploadTaskFile[]
  child         Child?           @relation("UploadTasks", fields: [childId], references: [id])
  family        Family           @relation("UploadTasks", fields: [familyId], references: [id], onDelete: Cascade)
  user          User             @relation("UploadTasks", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("upload_tasks")
}

model UploadTaskFile {
  id             String        @id @default(uuid())
  taskId         String        @map("task_id")
  fileName       String        @map("file_name")
  fileSize       BigInt        @map("file_size")
  checksum       String
  status         String        @default("PENDING")
  retryCount     Int           @default(0) @map("retry_count")
  errorMessage   String?       @map("error_message")
  uploadedBytes  BigInt        @default(0) @map("uploaded_bytes")
  totalChunks    Int           @default(1) @map("total_chunks")
  uploadedChunks Int           @default(0) @map("uploaded_chunks")
  photoId        String?       @map("photo_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  chunkUploads   ChunkUpload[]
  photo          Photo?        @relation("UploadTaskFiles", fields: [photoId], references: [id])
  task           UploadTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([status])
  @@index([checksum])
  @@map("upload_task_files")
}

model ChunkUpload {
  id           String         @id @default(uuid())
  fileRecordId String         @map("file_record_id")
  chunkIndex   Int            @map("chunk_index")
  chunkSize    Int            @map("chunk_size")
  etag         String
  uploadedAt   DateTime       @default(now()) @map("uploaded_at")
  fileRecord   UploadTaskFile @relation(fields: [fileRecordId], references: [id], onDelete: Cascade)

  @@unique([fileRecordId, chunkIndex])
  @@index([fileRecordId])
  @@map("chunk_uploads")
}

model Album {
  id             String      @id @default(uuid())
  familyId       String      @map("family_id")
  name           String
  description    String?
  coverPhotoId   String?     @map("cover_photo_id")
  isSmart        Boolean     @default(false) @map("is_smart")
  smartRules     String?     @map("smart_rules")
  sortOrder      Int         @default(0) @map("sort_order")
  photoCount     Int         @default(0) @map("photo_count")
  isShared       Boolean     @default(false) @map("is_shared")
  shareToken     String?     @unique @map("share_token")
  shareExpiresAt DateTime?   @map("share_expires_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  albumPhotos    AlbumPhoto[] @relation("AlbumPhotos")
  family         Family      @relation("FamilyAlbums", fields: [familyId], references: [id], onDelete: Cascade)
  shareLinks     ShareLink[] @relation("AlbumShareLinks")

  @@index([shareToken])
  @@index([familyId, isSmart])
  @@index([familyId, sortOrder])
  @@map("albums")
}

model AlbumPhoto {
  id        String   @id @default(uuid())
  albumId   String   @map("album_id")
  photoId   String   @map("photo_id")
  sortOrder Int      @default(0) @map("sort_order")
  addedAt   DateTime @default(now()) @map("added_at")
  addedBy   String   @map("added_by")
  photo     Photo    @relation("AlbumPhotos", fields: [photoId], references: [id], onDelete: Cascade)
  album     Album    @relation("AlbumPhotos", fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([albumId, photoId])
  @@index([photoId])
  @@index([albumId, sortOrder])
  @@map("album_photos")
}

model PhotoFace {
  id                  String       @id @default(uuid())
  photoId             String       @map("photo_id")
  awsFaceId           String?      @unique @map("aws_face_id")
  bounding_box        String
  confidence          Float
  emotion             String?
  emotionConfidence   Float?       @map("emotion_confidence")
  ageRangeLow         Int?         @map("age_range_low")
  ageRangeHigh        Int?         @map("age_range_high")
  gender              String?
  smile               Boolean?
  smileConfidence     Float?       @map("smile_confidence")
  glasses             String?
  beard               Boolean?
  mustache            Boolean?
  eyesOpen            Boolean?     @map("eyes_open")
  eyesOpenConfidence  Float?       @map("eyes_open_confidence")
  mouthOpen           Boolean?     @map("mouth_open")
  mouthOpenConfidence Float?       @map("mouth_open_confidence")
  landmarks           String?
  pose                String?
  quality             String?
  createdAt           DateTime     @default(now()) @map("created_at")
  personFaces         PersonFace[]
  photo               Photo        @relation("PhotoFaces", fields: [photoId], references: [id], onDelete: Cascade)

  @@index([photoId])
  @@index([awsFaceId])
  @@index([confidence])
  @@map("photo_faces")
}

model Person {
  id            String       @id @default(uuid())
  familyId      String       @map("family_id")
  name          String?
  avatarPhotoId String?      @map("avatar_photo_id")
  faceCount     Int          @default(0) @map("face_count")
  isConfirmed   Boolean      @default(false) @map("is_confirmed")
  birthYear     Int?         @map("birth_year")
  gender        String?
  relationship  String?
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  personFaces   PersonFace[]
  family        Family       @relation("FamilyPersons", fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([familyId, isConfirmed])
  @@index([familyId, faceCount(sort: Desc)])
  @@map("persons")
}

model PersonFace {
  id          String    @id @default(uuid())
  personId    String    @map("person_id")
  photoFaceId String    @map("photo_face_id")
  confidence  Float
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  photoFace   PhotoFace @relation(fields: [photoFaceId], references: [id], onDelete: Cascade)
  person      Person    @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, photoFaceId])
  @@index([personId, confidence(sort: Desc)])
  @@index([photoFaceId])
  @@map("person_faces")
}

model Milestone {
  id          String   @id @default(uuid())
  familyId    String   @map("family_id")
  childId     String?  @map("child_id")
  title       String
  description String?
  eventDate   DateTime @map("event_date")
  eventType   String   @map("event_type")
  importance  Int      @default(0)
  photoId     String?  @map("photo_id")
  location    String?
  mood        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  photo       Photo?   @relation("PhotoMilestones", fields: [photoId], references: [id])
  child       Child?   @relation("ChildMilestones", fields: [childId], references: [id])
  family      Family   @relation("FamilyMilestones", fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, eventDate(sort: Desc)])
  @@index([childId, eventDate(sort: Desc)])
  @@index([eventType])
  @@index([importance(sort: Desc)])
  @@map("milestones")
}

model ImportantDate {
  id           String   @id @default(uuid())
  familyId     String   @map("family_id")
  childId      String?  @map("child_id")
  title        String
  date         DateTime
  dateType     String   @map("date_type")
  isRecurring  Boolean  @default(true) @map("is_recurring")
  reminderDays Int      @default(0) @map("reminder_days")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  child        Child?   @relation("ChildImportantDates", fields: [childId], references: [id])
  family       Family   @relation("ImportantDates", fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, dateType])
  @@index([childId])
  @@map("important_dates")
}

model TimelineStats {
  id             String    @id @default(uuid())
  familyId       String    @map("family_id")
  childId        String?   @map("child_id")
  period         String
  periodType     String    @map("period_type")
  photoCount     Int       @default(0) @map("photo_count")
  milestoneCount Int       @default(0) @map("milestone_count")
  firstPhotoDate DateTime? @map("first_photo_date")
  lastPhotoDate  DateTime? @map("last_photo_date")
  ageAtPeriod    String?   @map("age_at_period")
  topTags        String?   @map("top_tags")
  topPersons     String?   @map("top_persons")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  child          Child?    @relation("TimelineStats", fields: [childId], references: [id])
  family         Family    @relation("TimelineStats", fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, childId, period, periodType])
  @@index([familyId, period(sort: Desc)])
  @@index([childId, period(sort: Desc)])
  @@map("timeline_stats")
}

// ========================================
// Phase 3 Models - 成长追踪与社交互动
// ========================================

// 成长记录模型 - 记录孩子的身高、体重、头围等生长指标
model GrowthRecord {
  id           String    @id @default(uuid())
  childId      String    @map("child_id")
  recordDate   DateTime  @map("record_date")  // 记录日期
  height       Float?    // 身高 (cm)
  weight       Float?    // 体重 (kg)
  headCirc     Float?    @map("head_circ")  // 头围 (cm)
  notes        String?   // 备注
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  child        Child     @relation("ChildGrowthRecords", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, recordDate])  // 同一天只能有一条记录
  @@index([childId, recordDate(sort: Desc)])
  @@map("growth_records")
}

// 成长报告模型 - 生成的成长报告
model GrowthReport {
  id          String    @id @default(uuid())
  childId     String    @map("child_id")
  startDate   DateTime  @map("start_date")  // 报告开始日期
  endDate     DateTime  @map("end_date")    // 报告结束日期
  reportType  String    @map("report_type") // MONTHLY | YEARLY | CUSTOM
  content     String?   // 报告内容 (JSON)
  pdfUrl      String?   @map("pdf_url")     // PDF文件URL
  imageUrl    String?   @map("image_url")   // 图片URL
  status      String    @default("PENDING") // PENDING | GENERATING | COMPLETED | FAILED
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  child       Child     @relation("ChildGrowthReports", fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, createdAt(sort: Desc)])
  @@index([status])
  @@map("growth_reports")
}

// 里程碑提醒模型 - 基于WHO发育里程碑的智能提醒
model MilestoneReminder {
  id            String    @id @default(uuid())
  childId       String    @map("child_id")
  milestoneType String    @map("milestone_type") // MOTOR | FINE_MOTOR | LANGUAGE | SOCIAL
  milestoneName String    @map("milestone_name") // 里程碑名称
  description   String?   // 描述
  ageMonths     Int       @map("age_months")     // 月龄
  reminderDate  DateTime  @map("reminder_date")  // 提醒日期
  isRead        Boolean   @default(false) @map("is_read")
  isCompleted   Boolean   @default(false) @map("is_completed")
  completedAt   DateTime? @map("completed_at")
  notes         String?   // 备注
  createdAt     DateTime  @default(now()) @map("created_at")
  child         Child     @relation("ChildMilestoneReminders", fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, reminderDate(sort: Desc)])
  @@index([childId, isRead])
  @@index([isRead])
  @@map("milestone_reminders")
}

// 分享链接模型 - 相册分享链接
model ShareLink {
  id             String         @id @default(uuid())
  albumId        String         @map("album_id")
  familyId       String         @map("family_id")
  token          String         @unique  // 分享Token (UUID)
  password       String?        // 密码 (bcrypt加密)
  title          String?        // 分享标题
  description    String?        // 分享描述
  theme          String?        // 主题样式
  allowComments  Boolean        @default(false) @map("allow_comments")  // 允许评论
  allowDownload  Boolean        @default(false) @map("allow_download")  // 允许下载
  expiresAt      DateTime?      @map("expires_at")  // 过期时间
  viewCount      Int            @default(0) @map("view_count")  // 访问次数
  commentCount   Int            @default(0) @map("comment_count")  // 评论数量
  lastViewedAt   DateTime?      @map("last_viewed_at")  // 最后访问时间
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  album          Album          @relation("AlbumShareLinks", fields: [albumId], references: [id], onDelete: Cascade)
  family         Family         @relation("FamilyShareLinks", fields: [familyId], references: [id], onDelete: Cascade)
  comments       ShareComment[] @relation("ShareLinkComments")

  @@index([token])
  @@index([familyId])
  @@index([albumId])
  @@index([expiresAt])
  @@map("share_links")
}

// 分享评论模型 - 分享链接的评论
model ShareComment {
  id          String    @id @default(uuid())
  shareLinkId String    @map("share_link_id")
  authorName  String    @map("author_name")  // 评论者名称 (匿名或登录用户)
  authorEmail String?   @map("author_email") // 评论者邮箱 (可选)
  content     String    // 评论内容
  emoji       String?   // Emoji表情
  likes       Int       @default(0)  // 点赞数
  parentId    String?   @map("parent_id")  // 父评论ID (支持回复)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  shareLink   ShareLink @relation("ShareLinkComments", fields: [shareLinkId], references: [id], onDelete: Cascade)
  parent      ShareComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     ShareComment[] @relation("CommentReplies")

  @@index([shareLinkId, createdAt(sort: Desc)])
  @@index([parentId])
  @@map("share_comments")
}
