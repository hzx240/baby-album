# ========== SECURITY WARNING ==========
# ⚠️ NEVER commit .env file to version control
# ⚠️ NEVER use default values in production
# =====================================

# Database Configuration
DATABASE_URL="file:./dev.db"
# For PostgreSQL production (RECOMMENDED):
# DATABASE_URL="postgresql://user:password@localhost:5432/baby_photos?schema=public"

# ========== JWT CONFIGURATION ==========
# ⚠️ IMPORTANT: Generate a secure random JWT secret for production!
#
# Development (OK for testing):
JWT_SECRET="dev-secret-key-32-chars-minimum-for-local-only"
#
# Production (MUST be at least 64 random characters):
# JWT_SECRET="your-production-jwt-secret-min-64-random-chars"
#
# Generate secure secret with one of these commands:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   openssl rand -base64 48

# Token TTL Configuration
JWT_EXPIRES_IN="15m"         # Access token expires in 15 minutes
REFRESH_TOKEN_EXPIRES_IN="30d"   # Refresh token expires in 30 days
#
# Security recommendations:
# - Access tokens: 5-15m (shorter is more secure)
# - Refresh tokens: 7-30d (balance security vs UX)

# ========== APPLICATION CONFIGURATION ==========
PORT=3001
NODE_ENV=development

# ========== S3/OBJECT STORAGE CONFIGURATION ==========
# Development (MinIO)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="baby-photos"
S3_REGION="us-east-1"

# Production (AWS S3)
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
# S3_BUCKET="your-bucket-name"
# S3_REGION="us-east-1"

# ========== REDIS CONFIGURATION ==========
# Required for distributed caching
REDIS_URL="redis://localhost:6379"

# Production with password:
# REDIS_URL="redis://:password@localhost:6379/0"

# Redis Cluster:
# REDIS_URL="redis://:password@redis-cluster.example.com:6379/0"

# ========== CORS CONFIGURATION ==========
CORS_ORIGIN="http://localhost:5173"

# ========== RATE LIMITING ==========
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ========== CACHE TTL CONFIGURATION ==========
# All values in seconds
CACHE_TTL_USER=600        # 10 minutes - User session cache
CACHE_TTL_PHOTO_URL=3600  # 1 hour - Photo URL cache
CACHE_TTL_FAMILY=1800     # 30 minutes - Family members cache
CACHE_TTL_UPLOAD=300       # 5 minutes - Upload progress cache

# ========== LOGGING CONFIGURATION ==========
LOG_LEVEL="debug"  # debug, info, warn, error
LOG_FORMAT="json"   # json or simple

# ========== SECURITY CONFIGURATION ==========

# Request size limits (prevent DoS attacks)
# Maximum JSON request body size
MAX_JSON_SIZE="10mb"  # 10 megabytes

# Maximum URL-encoded form size
MAX_URL_ENCODED_SIZE="10mb"  # 10 megabytes

# File upload limits
MAX_FILE_SIZE=10485760  # 10MB in bytes (single file)
MAX_FILE_SIZE_UPLOAD=52428800  # 50MB in bytes (S3 upload limit)
MAX_FILES_COUNT=20  # Maximum number of files per batch upload

# Allowed image types (comma-separated)
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp,image/heic"
