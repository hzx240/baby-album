# ========================================
# 宝贝成长相册 - 环境变量配置模板
# ========================================
# 使用方法：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改下面的配置值
# 3. 不要将 .env 文件提交到版本控制系统！
# ========================================

# ========================================
# 应用配置
# ========================================
NODE_ENV=development
# 应用运行环境: development | production

# ========================================
# PostgreSQL 数据库配置
# ========================================
POSTGRES_USER=babyuser
# 数据库用户名

POSTGRES_PASSWORD=babypass
# 数据库密码（生产环境请使用强密码）

POSTGRES_DB=babyalbum
# 数据库名称

DATABASE_URL=postgresql://babyuser:babypass@postgres:5432/babyalbum?schema=public
# 完整数据库连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名?schema=public
# 开发环境: postgresql://babyuser:babypass@localhost:5432/babyalbum?schema=public
# Docker 环境: postgresql://babyuser:babypass@postgres:5432/babyalbum?schema=public

# ========================================
# JWT 认证配置
# ========================================
# JWT_SECRET=$(node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# JWT 签名密钥（必须修改！）
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 生产环境建议使用 64+ 位随机字符串
JWT_SECRET=<GENERATE_WITH: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">

JWT_EXPIRES_IN=15m
# Access Token 过期时间
# 格式: 15m | 1h | 7d

REFRESH_TOKEN_EXPIRES_IN=30d
# Refresh Token 过期时间
# 格式: 7d | 30d | 90d

# ========================================
# MinIO 对象存储配置
# ========================================
S3_ENDPOINT=http://localhost:9000
# MinIO 服务端点
# 开发环境: http://localhost:9000
# Docker 环境: http://minio:9000

S3_ACCESS_KEY=minioadmin
# MinIO 访问密钥（默认: minioadmin）

S3_SECRET_KEY=minioadmin
# MinIO 秘密密钥（默认: minioadmin，生产环境必须修改）

S3_BUCKET=baby-photos
# 存储桶名称（需要预先创建）

S3_REGION=us-east-1
# AWS S3 区域（MinIO 可使用任意值）

# ========================================
# Redis 缓存配置
# ========================================
REDIS_HOST=localhost
# Redis 主机地址
# 开发环境: localhost
# Docker 环境: redis

REDIS_PORT=6379
# Redis 端口

REDIS_PASSWORD=redispass
# Redis 密码（可选）

# ========================================
# CORS 配置
# ========================================
CORS_ORIGIN=http://localhost:5173
# 允许的跨域来源
# 开发环境: http://localhost:5173
# 生产环境: http://yourdomain.com
# 多个域名用逗号分隔: http://localhost:5173,http://localhost:3000

# ========================================
# 速率限制配置
# ========================================
THROTTLE_TTL=60
# 速率限制时间窗口（秒）

THROTTLE_LIMIT=500
# 时间窗口内最大请求数

# ========================================
# 应用端口配置
# ========================================
BACKEND_PORT=3001
# 后端服务端口

FRONTEND_PORT=5173
# 前端开发服务器端口（仅开发环境）

# ========================================
# MinIO 管理员配置
# ========================================
MINIO_ROOT_USER=minioadmin
# MinIO 管理员用户名

MINIO_ROOT_PASSWORD=minioadmin
# MinIO 管理员密码（生产环境必须修改）
