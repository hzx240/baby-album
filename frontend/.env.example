# ========================================
# 宝贝成长相册 - 前端环境变量配置
# ========================================
# 前端应用专用环境变量
# Vite 构建时会注入这些变量（必须以 VITE_ 开头）
# ========================================

# ========================================
# API 配置
# ========================================
VITE_API_URL=http://localhost:3010/api
# 后端 API 地址
# 开发环境: http://localhost:3010/api
# Docker 环境: http://localhost:3010/api
# 生产环境: https://api.yourdomain.com/api

VITE_API_TIMEOUT=30000
# API 请求超时时间（毫秒）
# 默认: 30000 (30秒)

# ========================================
# 应用配置
# ========================================
VITE_APP_NAME=宝贝成长相册
# 应用名称

VITE_APP_DESCRIPTION=用爱记录宝宝的每一个珍贵瞬间
# 应用描述

# ========================================
# 功能开关
# ========================================
VITE_ENABLE_DARK_MODE=true
# 是否启用暗黑模式
# true | false

VITE_ENABLE_UPLOAD=true
# 是否启用上传功能
# true | false

VITE_ENABLE_DOWNLOAD=true
# 是否启用下载功能
# true | false

# ========================================
# 上传配置
# ========================================
VITE_MAX_FILE_SIZE=10485760
# 最大文件大小（字节）
# 默认: 10MB (10485760)

VITE_MAX_FILE_SIZE_MB=10
# 最大文件大小（MB，用于显示）
# 默认: 10

VITE_ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.gif,.webp,.heic
# 允许的文件类型（扩展名）
# 逗号分隔

VITE_MAX_UPLOAD_COUNT=50
# 单次最大上传文件数量
# 默认: 50

# ========================================
# 图片配置
# ========================================
VITE_IMAGE_QUALITY=80
# JPEG 压缩质量 (1-100)
# 默认: 80

VITE_THUMBNAIL_SIZE=300
# 缩略图尺寸（像素）
# 默认: 300

VITE_LAZY_LOAD_THRESHOLD=100
# 图片懒加载阈值（像素）
# 默认: 100（提前 100px 加载）

# ========================================
# 分页配置
# ========================================
VITE_PHOTOS_PER_PAGE=24
# 每页显示照片数量
# 默认: 24

VITE_LOAD_MORE_THRESHOLD=200
# 滚动加载更多阈值（像素）
# 距离底部多少像素时触发加载
# 默认: 200

# ========================================
# 缓存配置
# ========================================
VITE_CACHE_TTL=300000
# 客户端缓存时间（毫秒）
# 默认: 300000 (5分钟)

VITE_ENABLE_CACHE=true
# 是否启用客户端缓存
# true | false

# ========================================
# UI 配置
# ========================================
VITE_GRID_COLUMNS=auto
# 照片网格列数
# auto（自动）| 具体数字如 3, 4, 5

VITE_GRID_GAP=16
# 照片网格间距（像素）
# 默认: 16

VITE_ASPECT_RATIO=1
# 照片宽高比
# 1（正方形）| 1.33（4:3）| 1.77（16:9）

# ========================================
# 性能配置
# ========================================
VITE_ENABLE_VIRTUAL_SCROLL=true
# 是否启用虚拟滚动
# 大量照片时推荐启用
# true | false

VITE_VIRTUAL_ITEM_HEIGHT=300
# 虚拟滚动项目高度（像素）
# 默认: 300

VITE_BATCH_SIZE=20
# 批量加载照片数量
# 默认: 20

# ========================================
# 开发工具配置
# ========================================
VITE_ENABLE_DEVTOOLS=true
# 是否启用 React DevTools
# 仅开发环境有效
# true | false

VITE_LOG_LEVEL=info
# 日志级别
# debug | info | warn | error | silent

# ========================================
# 第三方服务配置
# ========================================
# VITE_GOOGLE_ANALYTICS_ID=
# Google Analytics ID
# 格式: G-XXXXXXXXXX

# VITE_SENTRY_DSN=
# Sentry 错误监控 DSN
# 格式: https://xxxxx@sentry.io/xxxxx

# ========================================
# 安全配置
# ========================================
VITE_ENABLE_HTTPS=false
# 是否强制使用 HTTPS
# 生产环境建议设置为 true
# true | false

VITE_STRICT_SSL=false
# 是否严格验证 SSL
# 开发环境可设为 false
# true | false

# ========================================
# 国际化配置
# ========================================
VITE_DEFAULT_LANGUAGE=zh-CN
# 默认语言
# zh-CN（简体中文）| en-US（英语）

VITE_ENABLE_I18N=false
# 是否启用多语言
# true | false

# ========================================
# CDN 配置（可选）
# ========================================
# VITE_CDN_URL=https://cdn.yourdomain.com
# 静态资源 CDN 地址
# 用于加速资源加载

# VITE_ENABLE_CDN=false
# 是否启用 CDN
# true | false

# ========================================
# WebSocket 配置
# ========================================
# VITE_ENABLE_WEBSOCKET=false
# 是否启用 WebSocket
# true | false

# VITE_WEBSOCKET_URL=ws://localhost:3001
# WebSocket 服务器地址

# ========================================
# 特性标志
# ========================================
VITE_FEATURE_ALBUM_VIEW=true
# 相册视图功能
# true | false

VITE_FEATURE_TIMELINE_VIEW=false
# 时间线视图功能（即将推出）
# true | false

VITE_FEATURE_AI_TAGGING=false
# AI 自动标签功能（即将推出）
# true | false

# ========================================
# 错误处理配置
# ========================================
VITE_SHOW_ERROR_DETAILS=false
# 是否显示错误详情
# 生产环境建议设为 false
# true | false

VITE_ERROR_REPORT_URL=
# 错误报告接口地址
# 格式: https://api.yourdomain.com/error-report

# ========================================
# 测试配置
# ========================================
VITE_ENABLE_MOCK_API=false
# 是否启用 Mock API
# 用于开发和测试
# true | false

VITE_MOCK_DELAY=500
# Mock API 响应延迟（毫秒）
# 默认: 500
